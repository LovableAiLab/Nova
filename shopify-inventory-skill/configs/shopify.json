{
  "api_version": "2024-01",
  "stores": [
    {
      "name": "main-store",
      "shop_url": "your-store.myshopify.com",
      "api_key": "your_api_key",
      "api_secret": "your_api_secret",
      "access_token": "your_access_token",
      "plan": "plus",
      "webhooks_enabled": true,
      "sync_enabled": true,
      "auto_fulfill": true
    }
  ],
  "webhooks": [
    {
      "topic": "orders/create",
      "address": "https://your-app.vercel.app/api/webhooks/orders",
      "format": "json"
    },
    {
      "topic": "orders/updated",
      "address": "https://your-app.vercel.app/api/webhooks/orders",
      "format": "json"
    },
    {
      "topic": "products/update",
      "address": "https://your-app.vercel.app/api/webhooks/products",
      "format": "json"
    },
    {
      "topic": "inventory_levels/update",
      "address": "https://your-app.vercel.app/api/webhooks/inventory",
      "format": "json"
    }
  ],
  "sync_settings": {
    "sync_interval": 300,
    "batch_size": 250,
    "max_retries": 3,
    "retry_delay": 5000,
    "timeout": 30000
  },
  "rate_limits": {
    "requests_per_minute": 40,
    "bucket_size": 40,
    "leak_rate": 2
  },
  "caching": {
    "enabled": true,
    "ttl": 300,
    "strategy": "lru",
    "max_size": 1000
  },
  "logging": {
    "level": "info",
    "format": "json",
    "destination": "console",
    "retention_days": 30
  },
  "security": {
    "encrypt_tokens": true,
    "ip_whitelist": [],
    "rate_limit_enabled": true,
    "audit_logging": true
  },
  "features": {
    "real_time_sync": true,
    "bulk_operations": true,
    "graphql_support": true,
    "webhook_validation": true,
    "error_recovery": true
  }
}